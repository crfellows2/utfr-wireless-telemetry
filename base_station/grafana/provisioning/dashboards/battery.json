    {
      "type": "stat",
      "title": "ACM",
      "description": "3=DRIVE, HV active and healthy.",
      "datasource": {
        "type": "grafana-mqtt-datasource",
        "uid": "mqtt"
      },
      "targets": [
        {
          "topic": "can/bus0/ACM/ACM_STATE",
          "datasource": {
            "type": "grafana-mqtt-datasource",
            "uid": "mqtt"
          },
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 1
      },
      "options": {
        "colorMode": "background_solid",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "LV ON",
                  "color": "blue"
                },
                "2": {
                  "text": "ENERGIZING",
                  "color": "yellow"
                },
                "3": {
                  "text": "DRIVE",
                  "color": "green"
                },
                "4": {
                  "text": "FAULT",
                  "color": "red"
                }
              }
            }
          ]
        },
        "overrides": []
      }
    },
