              },
              {
                "value": 5,
                "color": "red"
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "GOOD: Clean driving, maintain this pace",
                  "color": "green"
                },
                "1": {
                  "text": "THROTTLE: Be more progressive on corner exit \u2014 jerky inputs lose traction",
                  "color": "orange"
                },
                "2": {
                  "text": "STEERING: Reduce mid-corner corrections \u2014 smooth inputs or check setup",
                  "color": "orange"
                },
                "3": {
                  "text": "PEDALS: Separate throttle and brake \u2014 overlap wastes energy and heats brakes",
                  "color": "yellow"
                },
                "4": {
                  "text": "PACE: Too much coasting \u2014 stay on a pedal, minimize dead time",
                  "color": "yellow"
                },
                "5": {
                  "text": "TRACTION: Wheelspin detected \u2014 ease onto throttle more gradually",
                  "color": "red"
                }
              }
            }
          ]
        },
