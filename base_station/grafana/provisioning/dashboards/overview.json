        "h": 3,
        "w": 2,
        "x": 0,
        "y": 1
      },
      "options": {
        "colorMode": "background_solid",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
