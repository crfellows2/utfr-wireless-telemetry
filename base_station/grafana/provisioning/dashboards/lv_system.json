{
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "LV Battery",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "gauge",
      "title": "LV Voltage",
      "description": "Below 10V = brownout risk for controllers.",
      "datasource": {
        "type": "grafana-mqtt-datasource",
        "uid": "mqtt"
      },
      "targets": [
        {
          "topic": "can/bus0/LVBATT/LVBattVoltage",
          "datasource": {
            "type": "grafana-mqtt-datasource",
            "uid": "mqtt"
          },
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdMarkers": true,
        "showThresholdLabels": false
      },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "min": 8,
          "max": 14,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 10,
                "color": "yellow"
              },
              {
                "value": 11,
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "gauge",
      "title": "IMD Duty",
      "description": "HV isolation health. >80% = concern.",
      "datasource": {
        "type": "grafana-mqtt-datasource",
        "uid": "mqtt"
      },
      "targets": [
        {
          "topic": "can/bus0/IMD_STATUS/IMD_DUTY_CYCLE",
          "datasource": {
            "type": "grafana-mqtt-datasource",
            "uid": "mqtt"
          },
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdMarkers": true,
        "showThresholdLabels": false
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 80,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "LV Voltage Trend",
      "description": "Gradual decline normal. Sharp drops = weak battery.",
      "datasource": {
        "type": "grafana-mqtt-datasource",
        "uid": "mqtt"
      },
      "targets": [
        {
          "topic": "can/bus0/LVBATT/LVBattVoltage",
          "datasource": {
            "type": "grafana-mqtt-datasource",
            "uid": "mqtt"
          },
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 16,
        "x": 8,
        "y": 1
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      }
    },
